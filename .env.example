# =============================================================
# Variables pour docker-compose.yml (substitution ${VAR})
# =============================================================
# Copiez ce fichier en .env (racine du projet, à côté de docker-compose.yml)
# Ne committez JAMAIS le .env réel (déjà exclu par .gitignore).

# --- Accès SFTP au dossier uploads (conteneur atmoz/sftp) ---
SFTP_USER=chuushin
SFTP_PASSWORD=change_me_a_long_random_password

# --- Domaine du frontend (Caddy) ---
# Avec un nom de domaine nu (ex: chuushin.fr), Caddy active automatiquement
# le HTTPS (certificat Let's Encrypt) et redirige le HTTP vers HTTPS.
# Préfixez par "http://" pour désactiver le HTTPS auto (tests, pas de domaine
# final, ou pour éviter de cramer le quota Let's Encrypt en testant souvent).
SITE_DOMAIN=http://chuushin.ly-2940.eu
