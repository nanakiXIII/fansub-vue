{$SITE_DOMAIN:http://localhost} {
    encode gzip zstd

    handle /api/* {
        reverse_proxy backend:3000
    }

    handle /socket.io/* {
        reverse_proxy backend:3000
    }

    handle /uploads/* {
        reverse_proxy backend:3000
    }

    handle /media/* {
        reverse_proxy backend:3000
    }

    # Tout le reste (SPA) — dans son propre handle pour forcer cet ordre
    # après les blocs ci-dessus (file_server/try_files hors handle peuvent
    # s'exécuter avant eux, peu importe l'ordre d'écriture dans ce fichier).
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
