# =============================================================
# FRONTEND — Configuration de l'environnement
# =============================================================
# Copiez ce fichier en .env et adaptez les valeurs.
# Ne committez JAMAIS votre .env réel (il est dans .gitignore).
#
# Les variables VITE_ sont injectées dans le bundle client.
# Ne mettez JAMAIS de secrets (clés privées, tokens) dans VITE_.
# =============================================================


# -------------------------------------------------------------
# API Backend
# -------------------------------------------------------------

# URL de base de l'API (sans slash final)
# Dev local (avec proxy Vite)   : http://localhost:3000/api
# Dev local (sans proxy)        : http://localhost:3000/api
# Production                    : https://votre-domaine.fr/api
VITE_API_BASE_URL=http://localhost:3000/api

# URL de base pour les fichiers médias servis par le backend
# (utilisée pour construire les liens de téléchargement / streaming)
# Laissez vide si les médias sont servis depuis la même origine que l'API
VITE_MEDIA_BASE_URL=http://localhost:3000


# -------------------------------------------------------------
# Identité du site
# -------------------------------------------------------------

# Nom affiché dans la navbar, les onglets, les meta tags
VITE_SITE_NAME=

# Slogan affiché sur la page d'accueil
VITE_SITE_TAGLINE=Sous-titres français par la communauté

# Année affichée dans le footer
VITE_SITE_YEAR=2026

# URL publique du site (utilisée pour le SEO : canonical, sitemap, OG tags)
VITE_SITE_URL=https://votre-domaine.fr
VITE_SITE_DESCRIPTION=Sous-titres anime en français par la communauté


# -------------------------------------------------------------
# Intégrations externes
# -------------------------------------------------------------

# TMDB (The Movie Database) — pour la recherche et les métadonnées anime
# Clé gratuite sur : https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=

# Liens réseaux sociaux affichés dans le footer / à propos
# Laissez vide pour masquer le lien correspondant
VITE_DISCORD_URL=https://discord.gg/votre-serveur
VITE_TWITTER_URL=https://twitter.com/votre-compte
VITE_GITHUB_URL=https://github.com/votre-organisation
