# =============================================================
# BACKEND — Configuration de l'environnement
# =============================================================
# Copiez ce fichier en .env et adaptez les valeurs.
# Ne committez JAMAIS votre .env réel (il est dans .gitignore).
# =============================================================


# -------------------------------------------------------------
# Serveur
# -------------------------------------------------------------

# Port d'écoute du serveur Express
PORT=3000

# URL publique du site (utilisée pour le sitemap et le flux RSS)
SITE_URL=https://votre-domaine.fr

# Nom du site (utilisé dans le flux RSS — /rss.xml)
SITE_NAME=Fansub

# Origine(s) autorisée(s) pour CORS (URL du frontend)
# En production, remplacez par l'URL exacte de votre frontend
CORS_ORIGIN=http://localhost:5173

# URL publique du frontend (utilisée pour les redirections OAuth)
FRONTEND_URL=http://localhost:5173


# -------------------------------------------------------------
# Base de données
# -------------------------------------------------------------

# URI de connexion MongoDB
# Local  : mongodb://localhost:27017/fansub
# Atlas  : mongodb+srv://<user>:<password>@cluster.mongodb.net/fansub
MONGODB_URI=mongodb://localhost:27017/fansub


# -------------------------------------------------------------
# Authentification JWT
# -------------------------------------------------------------

# Secret de signature des tokens d'accès (15 min par défaut)
# Générez une valeur aléatoire forte : openssl rand -hex 64
JWT_SECRET=change_me_to_a_long_random_string

# Durée de vie du token d'accès (recommandé : 15m)
JWT_EXPIRES_IN=15m

# Secret de signature des refresh tokens (7 jours)
# DOIT être différent de JWT_SECRET
# Générez : openssl rand -hex 64
JWT_REFRESH_SECRET=change_me_to_another_long_random_string


# -------------------------------------------------------------
# Promotion admin (usage unique)
# -------------------------------------------------------------
# Token permettant à un compte connecté de se promouvoir admin via
# la page /devenir-admin, sans toucher à la base de données.
# Usage unique : une fois consommé, voir backend/data/admin-claim.used
# (supprimez ce fichier ou changez la valeur ci-dessous pour le réutiliser).
# Générez : openssl rand -hex 24
# Laissez vide pour désactiver la fonctionnalité.
ADMIN_CLAIM_TOKEN=f0ec9474987e4df13cf46f06db16b4155653660f22b0e82e


# -------------------------------------------------------------
# E-mail (SMTP) — vérification d'adresse et mot de passe oublié
# -------------------------------------------------------------
# Laissez SMTP_HOST vide en dev : les e-mails (lien de vérification, reset
# de mot de passe) sont alors affichés dans la console du serveur au lieu
# d'être envoyés, pour pouvoir tester sans configurer de vrai SMTP.

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Adresse affichée comme expéditeur (par défaut : SMTP_USER)
SMTP_FROM=


# -------------------------------------------------------------
# OAuth — Google
# -------------------------------------------------------------
# Créez un projet sur https://console.cloud.google.com
# → API & Services → Identifiants → Créer des identifiants OAuth 2.0
# URI de redirection autorisée : <OAUTH_CALLBACK_BASE>/api/auth/google/callback

# Laissez vide pour désactiver la connexion Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# -------------------------------------------------------------
# OAuth — Discord
# -------------------------------------------------------------
# Créez une application sur https://discord.com/developers/applications
# → OAuth2 → Redirects : <OAUTH_CALLBACK_BASE>/api/auth/discord/callback

# Laissez vide pour désactiver la connexion Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=


# -------------------------------------------------------------
# OAuth — URL de callback
# -------------------------------------------------------------
# Base URL utilisée pour construire les URL de callback OAuth.
# En dev local avec Vite proxy : http://localhost:5173
# En production avec reverse proxy : https://votre-domaine.fr
OAUTH_CALLBACK_BASE=http://localhost:5173


# -------------------------------------------------------------
# Alertes Discord
# -------------------------------------------------------------
# Créez un webhook dans Discord : Paramètres du salon → Intégrations
# → Webhooks → Nouveau webhook → Copier l'URL du webhook.
# Une alerte est postée dans ce salon à chaque publication d'actualité.

# Laissez vide pour désactiver les alertes Discord
DISCORD_WEBHOOK_URL=


# -------------------------------------------------------------
# Médias (vidéos / sous-titres)
# -------------------------------------------------------------

# Chemin absolu vers le dossier contenant les fichiers vidéo
# Laissez vide si vous ne servez pas de vidéos depuis ce serveur
MEDIA_ROOT=/chemin/vers/vos/videos

# Chemin vers l'exécutable ffmpeg (pour l'extraction de sous-titres)
# Linux/Mac : /usr/bin/ffmpeg  |  Windows : C:\ffmpeg\bin\ffmpeg.exe
# Laissez vide pour utiliser ffmpeg depuis le PATH système
FFMPEG_PATH=
